# Test Environment Variables
# Copy this file to .env and fill in your values

# API Key for running integration tests
TEST_API_KEY=your-api-key-here

# API Base URL (optional, defaults to https://api.deepseek.com)
TEST_API_BASE_URL=https://api.deepseek.com

# Model name for tests (optional, defaults to deepseek-reasoner)
TEST_MODEL_NAME=deepseek-reasoner